# Multi-stage build
FROM golang:1.26-alpine AS builder

# Install build dependencies
# Including ca-certificates for secure module downloads
RUN apk add --no-cache git make ca-certificates

WORKDIR /build

# Copy go mod files first to cache dependencies
COPY go.mod go.sum* ./

# Download dependencies - ensures consistent versions for messagebroker imports
RUN go mod download

# Copy source code
COPY . .

# Build binary
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-w -s" \
    -o telemetry-streamer \
    ./cmd/telemetry-streamer

# Runtime stage
FROM alpine:3.18

# Install runtime dependencies
RUN apk add --no-cache ca-certificates tzdata

# Create non-root user
RUN addgroup -g 1000 telemetry && \
    adduser -D -u 1000 -G telemetry telemetry

# Create data directory
RUN mkdir -p /data && \
    chown telemetry:telemetry /data

WORKDIR /home/telemetry

# Copy binary from builder - fixed path to match build output
COPY --from=builder --chown=telemetry:telemetry /build/telemetry-streamer .

# Switch to non-root user
USER telemetry

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost:8080/health || exit 1

# Expose health port
EXPOSE 8080

# Run application
ENTRYPOINT ["./telemetry-streamer"]
