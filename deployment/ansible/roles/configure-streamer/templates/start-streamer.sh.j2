#!/bin/bash
# Telemetry Streamer Startup Script

set -e

# Load configuration
if [ -f /var/lib/telemetry/config/telemetry.env ]; then
    set -a
    source /var/lib/telemetry/config/telemetry.env
    set +a
fi

# Set defaults
SERVICE_NAME="${SERVICE_NAME:-telemetry-streamer}"
CONTAINER_NAME="${SERVICE_NAME}-$(hostname)"
DOCKER_IMAGE="{{ docker_image | default('telemetry-streaming:latest') }}"
DATA_VOLUME="/var/lib/telemetry/data"
LOG_VOLUME="/var/lib/telemetry/logs"

echo "Starting $SERVICE_NAME..."

# Pull latest image
docker pull "$DOCKER_IMAGE" || true

# Stop existing container if running
docker stop "$CONTAINER_NAME" 2>/dev/null || true
docker rm "$CONTAINER_NAME" 2>/dev/null || true

# Run Docker container
docker run \
    --name "$CONTAINER_NAME" \
    --rm \
    --restart=unless-stopped \
    --log-driver=json-file \
    --log-opt max-size=100m \
    --log-opt max-file=10 \
    -v "$DATA_VOLUME":/data:ro \
    -v "$LOG_VOLUME":/var/log/telemetry \
    -p 8080:8080 \
    -e SERVICE_NAME="$SERVICE_NAME" \
    -e SERVICE_ID="{{ service_id | default('1') }}" \
    -e HEALTH_PORT=8080 \
    -e LOG_LEVEL="$LOG_LEVEL" \
    -e CSV_FILE_PATH="$CSV_FILE_PATH" \
    -e READ_SPEED="$READ_SPEED" \
    -e BROKER_ADDRESSES="$BROKER_ADDRESSES" \
    -e TOPIC="$TOPIC" \
    -e REPLICATION_FACTOR="$REPLICATION_FACTOR" \
    -e BATCH_SIZE="$BATCH_SIZE" \
    -e BATCH_TIMEOUT_MS="$BATCH_TIMEOUT_MS" \
    -e COMPRESSION_TYPE="$COMPRESSION_TYPE" \
    -e ACKS="$ACKS" \
    -e MAX_RETRIES="$MAX_RETRIES" \
    -e RETRY_BACKOFF_MS="$RETRY_BACKOFF_MS" \
    -e CIRCUIT_BREAKER_THRESHOLD="$CIRCUIT_BREAKER_THRESHOLD" \
    -e HEALTH_CHECK_INTERVAL="$HEALTH_CHECK_INTERVAL" \
    -e GRACEFUL_SHUTDOWN_TIMEOUT="$GRACEFUL_SHUTDOWN_TIMEOUT" \
    "$DOCKER_IMAGE"
