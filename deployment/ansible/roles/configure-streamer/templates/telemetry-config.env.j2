# Telemetry Streaming Service Configuration
# Generated by Ansible

# Service Configuration
SERVICE_NAME=telemetry-streamer
SERVICE_ID=1
HEALTH_PORT=8080
LOG_LEVEL={{ log_level | default('info') }}

# CSV Configuration
CSV_FILE_PATH=/var/lib/telemetry/data/telemetry.csv
READ_SPEED={{ read_speed | default(100) }}

# Message Broker Configuration
BROKER_ADDRESSES={{ broker_addresses | default('localhost:9092') }}
TOPIC={{ topic | default('telemetry') }}
REPLICATION_FACTOR={{ replication_factor | default(3) }}

# Producer Configuration
BATCH_SIZE={{ batch_size | default(50) }}
BATCH_TIMEOUT_MS={{ batch_timeout_ms | default(1000) }}
COMPRESSION_TYPE={{ compression_type | default('snappy') }}
ACKS={{ acks | default('all') }}

# Resilience Configuration
MAX_RETRIES={{ max_retries | default(5) }}
RETRY_BACKOFF_MS={{ retry_backoff_ms | default(100) }}
CIRCUIT_BREAKER_THRESHOLD={{ circuit_breaker_threshold | default(10) }}
HEALTH_CHECK_INTERVAL={{ health_check_interval | default(30) }}

# Shutdown Configuration
GRACEFUL_SHUTDOWN_TIMEOUT={{ graceful_shutdown_timeout | default(30) }}
